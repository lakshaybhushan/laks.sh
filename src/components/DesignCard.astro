---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
	altText: string;
	title: string;
	link: string;
	imageUrl: string;
}

const { altText, title, link, imageUrl } = Astro.props;
---

<div class="flex flex-col items-start">
	<!-- <a href={link} target="_blank" rel="noreferrer"> -->
	<div class="pt-2">
		<Image src={imageUrl} alt={altText} class="border-body/20 rounded-lg border" format="avif" inferSize={true} />
		<!-- <div class="pt-1">
			<p class="text-body text-sm">{title}</p>
		</div> -->
	</div>
</div>

<!-- </a> -->
